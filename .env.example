EMUSASOFT_MCP_TOKEN=
EMUSASOFT_MCP_URL=https://emusa-mcp-tasks-stg-api.emusa.dev

# EMUSASOFT_MCP_URL is the base URL. MCP JSON-RPC requests use its /mcp route.

# Monitor local development only. Do not place production credentials here.
MONITOR_NODE_ENV=development
MONITOR_HOST=127.0.0.1
MONITOR_PORT=3000
MONITOR_WEB_ORIGIN=http://127.0.0.1:5173
MONITOR_COOKIE_SECRET=replace-with-a-random-local-value-at-least-32-characters
MONITOR_ALLOW_MOCK_AUTH=true
MONITOR_DATABASE_MODE=pglite
MONITOR_PGLITE_DATA_DIR=local-data/monitor/pglite
MONITOR_DATABASE_URL=
MONITOR_REDIS_URL=
MONITOR_FEATURE_DASHBOARD_SHELL=true
MONITOR_FEATURE_CHAT_SHELL=true
MONITOR_FEATURE_ROSTER_SHELL=false
