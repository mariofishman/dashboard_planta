{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Monitor",
    "sources": [
      "https://tweakcn.com/themes/cml5dyjea000004jr66ytcg0l",
      "https://emusa.com.pe/es/"
    ],
    "strategy": "EMUSA provides brand identity; Vescrow 1.2 provides product UI grammar."
  },
  "color": {
    "brand": {
      "navy": { "$value": "#00246B", "$type": "color" },
      "navyActive": { "$value": "#001B52", "$type": "color" },
      "cyan": { "$value": "#007ACC", "$type": "color" },
      "cyanHover": { "$value": "#006BA8", "$type": "color" },
      "green": { "$value": "#008A49", "$type": "color" },
      "signalCyan": { "$value": "#01A2C6", "$type": "color" }
    },
    "surface": {
      "canvas": { "$value": "#F5F5F5", "$type": "color" },
      "default": { "$value": "#FFFFFF", "$type": "color" },
      "selected": { "$value": "#E2EBFD", "$type": "color" },
      "border": { "$value": "#E0E0E0", "$type": "color" }
    },
    "text": {
      "default": { "$value": "#00246B", "$type": "color" },
      "muted": { "$value": "#4D608A", "$type": "color" },
      "inverse": { "$value": "#FFFFFF", "$type": "color" }
    },
    "status": {
      "success": { "$value": "#008A49", "$type": "color" },
      "info": { "$value": "#007ACC", "$type": "color" },
      "warning": { "$value": "#F97316", "$type": "color" },
      "danger": { "$value": "#E11D48", "$type": "color" }
    },
    "chart": {
      "one": { "$value": "#007ACC", "$type": "color" },
      "two": { "$value": "#008A49", "$type": "color" },
      "three": { "$value": "#8B5CF6", "$type": "color" },
      "four": { "$value": "#D946EF", "$type": "color" },
      "five": { "$value": "#F97316", "$type": "color" }
    }
  },
  "font": {
    "family": { "$value": "Montserrat, system-ui, sans-serif", "$type": "fontFamily" },
    "size": {
      "routine": { "$value": "0.6875rem", "$type": "dimension" },
      "xs": { "$value": "0.75rem", "$type": "dimension" },
      "sm": { "$value": "0.8125rem", "$type": "dimension" },
      "md": { "$value": "0.875rem", "$type": "dimension" },
      "base": { "$value": "1rem", "$type": "dimension" },
      "lg": { "$value": "1.25rem", "$type": "dimension" },
      "xl": { "$value": "2rem", "$type": "dimension" },
      "display": { "$value": "3.25rem", "$type": "dimension" }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    }
  },
  "spacing": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "6px", "$type": "dimension" },
    "md": { "$value": "10px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "pill": { "$value": "9999px", "$type": "dimension", "$description": "Only for genuinely circular elements such as status dots, avatars, and unread counters; never rectangular controls, filters, or chips." }
  },
  "control": {
    "compactHeight": { "$value": "28px", "$type": "dimension" },
    "compactPaddingInline": { "$value": "8px", "$type": "dimension" },
    "accessibleHitTarget": { "$value": "44px", "$type": "dimension" }
  },
  "semantic": {
    "color": {
      "structure": { "$value": "{color.brand.navy}", "$type": "color" },
      "action": { "$value": "{color.brand.cyan}", "$type": "color" },
      "actionHover": { "$value": "{color.brand.cyanHover}", "$type": "color" },
      "canvas": { "$value": "{color.surface.canvas}", "$type": "color" },
      "surface": { "$value": "{color.surface.default}", "$type": "color" },
      "selected": { "$value": "{color.surface.selected}", "$type": "color" },
      "border": { "$value": "{color.surface.border}", "$type": "color" },
      "textPrimary": { "$value": "{color.text.default}", "$type": "color" },
      "textSecondary": { "$value": "{color.text.muted}", "$type": "color" },
      "textInverse": { "$value": "{color.text.inverse}", "$type": "color" },
      "textInverseMuted": { "$value": "rgba(255,255,255,.74)", "$type": "color" },
      "inverseDivider": { "$value": "rgba(255,255,255,.12)", "$type": "color" },
      "inverseSkeleton": { "$value": "rgba(255,255,255,.18)", "$type": "color" },
      "lifecycleResolved": { "$value": "{color.status.success}", "$type": "color" },
      "lifecycleOpen": { "$value": "{color.status.danger}", "$type": "color" },
      "lifecycleClosed": { "$value": "{color.status.warning}", "$type": "color" }
    },
    "typography": {
      "routine": { "$value": "{font.size.routine}", "$type": "dimension" },
      "primaryData": { "$value": "{font.size.xs}", "$type": "dimension" },
      "sectionTitle": { "$value": "{font.size.md}", "$type": "dimension" },
      "body": { "$value": "{font.size.base}", "$type": "dimension" }
    },
    "control": {
      "visibleHeight": { "$value": "{control.compactHeight}", "$type": "dimension" },
      "paddingInline": { "$value": "{control.compactPaddingInline}", "$type": "dimension" },
      "radius": { "$value": "{radius.sm}", "$type": "dimension" },
      "desktopHitTarget": { "$value": "40px", "$type": "dimension" },
      "touchHitTarget": { "$value": "{control.accessibleHitTarget}", "$type": "dimension" }
    }
  },
  "shadow": {
    "low": { "$value": "0 1px 3px rgba(0,0,0,.08)", "$type": "shadow" },
    "hover": { "$value": "0 4px 12px rgba(0,0,0,.12)", "$type": "shadow" },
    "nav": { "$value": "0 2px 8px rgba(0,0,0,.06)", "$type": "shadow" },
    "dialog": { "$value": "0 16px 40px rgba(0,36,107,.16)", "$type": "shadow" }
  },
  "motion": {
    "fast": { "$value": "150ms", "$type": "duration" },
    "standard": { "$value": "200ms", "$type": "duration" },
    "easeOut": { "$value": "cubic-bezier(0.22, 1, 0.36, 1)", "$type": "cubicBezier" }
  }
}
