{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monitor.emusa.dev/contracts/detection-query/1.1.0",
  "title": "Monitor detection query contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion", "alertTypeCode", "queryId", "queryVersion",
    "keySchemaVersion", "naturalKey", "output", "sqlFile", "timeoutMs",
    "resultLimit", "cycleRowLimit", "paginationKey", "pollingIntervalSeconds", "resolutionPolicy", "validation"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "contractVersion": { "const": "1.1.0" },
    "alertTypeCode": { "type": "string", "pattern": "^[A-Z][0-9]{2}$" },
    "queryId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "queryVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-candidate)?$" },
    "keySchemaVersion": { "type": "integer", "minimum": 1 },
    "naturalKey": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" }
    },
    "output": {
      "type": "object", "minProperties": 1,
      "additionalProperties": { "enum": ["integer", "number", "string", "boolean", "timestamp", "nullable-integer", "nullable-string", "nullable-timestamp"] }
    },
    "sqlFile": { "type": "string" },
    "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 30000 },
    "resultLimit": { "type": "integer", "minimum": 1, "maximum": 5000 },
    "cycleRowLimit": { "type": "integer", "minimum": 1, "maximum": 50000 },
    "paginationKey": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*$" },
    "pollingIntervalSeconds": { "type": "integer", "minimum": 30 },
    "resolutionPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["requiresCompleteHealthyCycle", "usesReplicaObservationBoundary"],
      "properties": {
        "requiresCompleteHealthyCycle": { "const": true },
        "usesReplicaObservationBoundary": { "const": true }
      }
    },
    "validation": {
      "type": "object", "additionalProperties": false,
      "required": ["localBackupRevision", "productionStatus"],
      "properties": {
        "localBackupRevision": { "type": "string" },
        "productionStatus": { "enum": ["pending-es2-01-es2-02", "approved"] }
      }
    }
  }
}
