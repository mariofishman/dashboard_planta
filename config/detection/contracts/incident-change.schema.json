{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://monitor.emusa.dev/contracts/incident-change/1.0.0",
  "title": "Monitor committed incident change",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "eventId", "cursor", "type", "occurredAt", "incidentId", "plantId", "payload"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "eventId": { "type": "string", "format": "uuid" },
    "cursor": { "type": "integer", "minimum": 1 },
    "type": { "enum": ["incident.created", "incident.updated", "incident.resolved", "incident.closed_without_resolution"] },
    "occurredAt": { "type": "string", "format": "date-time" },
    "incidentId": { "type": "string", "format": "uuid" },
    "plantId": { "type": "integer", "minimum": 1 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alertTypeCode", "lifecycle", "queryId", "queryVersion", "conditionKey"],
      "properties": {
        "alertTypeCode": { "type": "string", "pattern": "^[A-Z][0-9]{2}$" },
        "lifecycle": { "enum": ["OPEN", "RESOLVED", "CLOSED_WITHOUT_RESOLUTION"] },
        "queryId": { "type": "string" },
        "queryVersion": { "type": "string" },
        "conditionKey": { "type": "string", "minLength": 1 }
      }
    }
  }
}
